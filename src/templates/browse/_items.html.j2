{# Fragment HTMX — remplace le contenu de #spell-list #}

<!-- Compteur -->
<div class="flex items-center justify-between mb-4">
  <p class="text-sm text-gray-500">
    {% if total == 0 %}Aucun sort trouvé
    {% elif total == 1 %}1 sort
    {% else %}{{ total }} sorts{% endif %}
    {% if filters.q or filters.school or filters.classe %}
      <span class="text-gray-400">— filtrés</span>
    {% endif %}
  </p>
  {% if pages > 1 %}
  <p class="text-sm text-gray-500">Page {{ page }}/{{ pages }}</p>
  {% endif %}
</div>

<!-- Grille de sorts -->
{% if spells %}
<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-3">
  {% for spell in spells %}
  <a href="/spells/{{ spell['slug_fr'] }}"
     class="group block bg-white rounded-xl shadow-sm border border-gray-100
            hover:shadow-md hover:border-gray-200 transition-all overflow-hidden">

    <!-- Bande couleur école -->
    <div class="h-1.5" style="background-color: {{ spell['school'] | school_color }};"></div>

    <div class="p-4">
      <!-- École + niveaux -->
      <div class="flex items-start justify-between gap-2 mb-1">
        <div class="flex flex-wrap gap-1">
          <span class="inline-flex items-center gap-1 text-xs font-semibold px-2 py-0.5 rounded-full text-white"
                style="background-color: {{ spell['school'] | school_color }};">
            {{ spell['school'] | school_icon | safe }}{{ spell['school'] | capitalize }}
          </span>
          {% if spell['is_custom'] %}
          <span class="inline-flex items-center text-xs font-semibold px-2 py-0.5 rounded-full bg-violet-100 text-violet-700">✦</span>
          {% endif %}
        </div>
        <span class="text-xs text-gray-400 shrink-0">
          {{ spell['level_json'] | format_levels }}
        </span>
      </div>

      <!-- Nom -->
      <h3 class="font-semibold text-gray-900 group-hover:text-amber-700 transition-colors leading-snug">
        {{ spell['name_fr'] }}
      </h3>

      <!-- Métadonnées clés -->
      <div class="mt-2 flex flex-wrap gap-x-3 gap-y-0.5 text-xs text-gray-500">
        {% if spell['casting_time'] %}
        <span title="Temps d'incantation">⏱ {{ spell['casting_time'] }}</span>
        {% endif %}
        {% if spell['components'] %}
        <span title="Composantes">◈ {{ spell['components'] }}</span>
        {% endif %}
        {% if spell['spell_range'] %}
        <span title="Portée">⇥ {{ spell['spell_range'] | truncate(20, true, '…') }}</span>
        {% endif %}
      </div>
    </div>
  </a>
  {% endfor %}
</div>

<!-- Pagination -->
{% if pages > 1 %}
<nav class="mt-6 flex items-center justify-center gap-1" aria-label="Pagination">
  {% if page > 1 %}
  <a href="?{{ filters | urlencode_filters }}&page={{ page - 1 }}"
     hx-get="/spells?{{ filters | urlencode_filters }}&page={{ page - 1 }}"
     hx-target="#spell-list" hx-push-url="true"
     class="px-3 py-1.5 rounded-lg border text-sm hover:bg-gray-50 transition-colors">
    ← Préc.
  </a>
  {% endif %}

  {% for p in range([1, page - 2] | max, [pages + 1, page + 3] | min) %}
  <a href="?{{ filters | urlencode_filters }}&page={{ p }}"
     hx-get="/spells?{{ filters | urlencode_filters }}&page={{ p }}"
     hx-target="#spell-list" hx-push-url="true"
     class="px-3 py-1.5 rounded-lg border text-sm transition-colors
            {% if p == page %}bg-amber-500 text-white border-amber-500{% else %}hover:bg-gray-50{% endif %}">
    {{ p }}
  </a>
  {% endfor %}

  {% if page < pages %}
  <a href="?{{ filters | urlencode_filters }}&page={{ page + 1 }}"
     hx-get="/spells?{{ filters | urlencode_filters }}&page={{ page + 1 }}"
     hx-target="#spell-list" hx-push-url="true"
     class="px-3 py-1.5 rounded-lg border text-sm hover:bg-gray-50 transition-colors">
    Suiv. →
  </a>
  {% endif %}
</nav>
{% endif %}

{% else %}
<div class="text-center py-16 text-gray-400">
  <svg class="w-12 h-12 mx-auto mb-3 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
          d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
  </svg>
  <p>Aucun sort ne correspond à ces filtres.</p>
  <a href="/spells" class="mt-2 inline-block text-sm text-amber-600 hover:underline">
    Voir tous les sorts
  </a>
</div>
{% endif %}
